object victoria {
    var edad
    var altura
    var objetoImportante
    var disciplina
    var presupuestoPropio = numeroEntrenadores + entrenador.valor()
    var presupuestoBase
    var numeroEntrenadores

    method presupuesto() = presupuestoBase + presupuestoPropio
}

object entrenador {
    var valor

    method valor() = valor
}